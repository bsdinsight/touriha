<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===== Loại xe ===== -->
    <record id="view_touriha_vehicle_type_list" model="ir.ui.view">
        <field name="name">touriha.vehicle.type.list</field>
        <field name="model">touriha.vehicle.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="seat_capacity"/>
                <field name="price"/>
                <field name="supplier_id"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_touriha_vehicle_type_form" model="ir.ui.view">
        <field name="name">touriha.vehicle.type.form</field>
        <field name="model">touriha.vehicle.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="seat_capacity"/>
                        <field name="price"/>
                        <field name="supplier_id"/>
                        <field name="active"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_touriha_vehicle_type" model="ir.actions.act_window">
        <field name="name">Loại xe</field>
        <field name="res_model">touriha.vehicle.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_touriha_vehicle_type"
              name="Loại xe"
              parent="touriha_base.touriha_config_menu"
              action="action_touriha_vehicle_type"
              sequence="20"/>

    <!-- ===== Gợi ý xe trên form Tour (tab Định mức) ===== -->
    <record id="view_touriha_tour_form_vehicle" model="ir.ui.view">
        <field name="name">touriha.tour.form.vehicle</field>
        <field name="model">touriha.tour</field>
        <field name="inherit_id" ref="touriha_operations.view_touriha_tour_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='auto_quantity']" position="inside">
                <group string="Gợi ý phương tiện (Best-fit theo chi phí)">
                    <field name="vehicle_suggestion"/>
                    <field name="vehicle_suggestion_cost"/>
                    <field name="currency_id" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
