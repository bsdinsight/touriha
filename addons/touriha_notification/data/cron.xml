<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_departure_reminder" model="ir.cron">
        <field name="name">Touriha: Nhắc khởi hành (email)</field>
        <field name="model_id" ref="touriha_operations.model_touriha_tour"/>
        <field name="state">code</field>
        <field name="code">model._cron_departure_reminder()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall">2026-06-10 21:00:00</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Số ngày trước khởi hành để nhắc (chỉnh ở Cài đặt > Thông số kỹ thuật) -->
    <record id="param_departure_reminder_days" model="ir.config_parameter">
        <field name="key">touriha.departure_reminder_days</field>
        <field name="value">3</field>
    </record>
</odoo>
