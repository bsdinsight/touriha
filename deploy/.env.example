# ── /root/touriha/.env trên VPS — copy từ template này rồi sửa ──
# KHÔNG commit .env thật (đã trong .gitignore).

# Mật khẩu mạnh cho Postgres user `odoo`. Tạo vd:
#   openssl rand -base64 32
# Đặt TRƯỚC lần `up -d db` đầu tiên — Postgres chỉ áp khi init data dir rỗng.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM

# Token Cloudflare Tunnel cho "Touriha VPS".
# Zero Trust → Networks → Tunnels → (tunnel touriha) → token (eyJ...)
# Tunnel route hostname → http://odoo:8069 (dbfilter=^%d$ chọn DB trùng tên):
#   touriha.bsdinsights.com → DB touriha
TUNNEL_TOKEN=CHANGE_ME_TUNNEL_TOKEN
