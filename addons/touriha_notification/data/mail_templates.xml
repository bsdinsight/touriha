<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Xác nhận tour → khách hàng -->
        <record id="mail_template_tour_confirmed" model="mail.template">
            <field name="name">Touriha: Xác nhận tour</field>
            <field name="model_id" ref="touriha_operations.model_touriha_tour"/>
            <field name="subject">Xác nhận tour {{ object.name }} ({{ object.code }})</field>
            <field name="email_to">{{ object.customer_id.email }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <div style="font-family:Arial,sans-serif;font-size:14px">
                    <p>Kính gửi <t t-out="object.customer_id.name or 'Quý khách'"/>,</p>
                    <p>Touriha xác nhận tour của quý khách:</p>
                    <ul>
                        <li><b>Tour:</b> <t t-out="object.name or ''"/> (<t t-out="object.code or ''"/>)</li>
                        <li><b>Khởi hành:</b> <t t-out="object.start_date or ''"/> — <b>Kết thúc:</b> <t t-out="object.end_date or ''"/></li>
                        <li><b>Số khách:</b> <t t-out="object.passenger_count or 0"/></li>
                    </ul>
                    <p>Cảm ơn quý khách đã tin tưởng Touriha!</p>
                </div>
            </field>
        </record>

        <!-- Gửi PO → nhà cung cấp -->
        <record id="mail_template_po_supplier" model="mail.template">
            <field name="name">Touriha: Đơn mua hàng cho NCC</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">Đơn mua hàng {{ object.name }} từ Touriha</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <div style="font-family:Arial,sans-serif;font-size:14px">
                    <p>Kính gửi <t t-out="object.partner_id.name or 'Quý đối tác'"/>,</p>
                    <p>Touriha gửi đơn mua hàng <b><t t-out="object.name or ''"/></b>
                       (tour <t t-out="object.tour_id.name or object.origin or ''"/>),
                       tổng giá trị <t t-out="object.amount_total" t-options='{"widget":"monetary","display_currency":object.currency_id}'/>.</p>
                    <p>Vui lòng đăng nhập <b>cổng đối tác</b> để xác nhận hoặc từ chối:
                       <a t-attf-href="/my/touriha/purchases">/my/touriha/purchases</a></p>
                    <p>Trân trọng,<br/>Touriha</p>
                </div>
            </field>
        </record>

        <!-- Xác nhận hoàn tiền → khách hàng -->
        <record id="mail_template_refund" model="mail.template">
            <field name="name">Touriha: Xác nhận hoàn tiền</field>
            <field name="model_id" ref="touriha_cancellation.model_touriha_cancellation_request"/>
            <field name="subject">Xác nhận hoàn tiền - tour {{ object.tour_id.name }}</field>
            <field name="email_to">{{ object.tour_id.customer_id.email }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <div style="font-family:Arial,sans-serif;font-size:14px">
                    <p>Kính gửi <t t-out="object.tour_id.customer_id.name or 'Quý khách'"/>,</p>
                    <p>Touriha xác nhận đã xử lý hủy tour <b><t t-out="object.tour_id.name or ''"/></b>:</p>
                    <ul>
                        <li>Phí hủy (<t t-out="object.penalty_rate or 0"/>%): <t t-out="object.penalty_amount" t-options='{"widget":"monetary","display_currency":object.currency_id}'/></li>
                        <li><b>Hoàn lại:</b> <t t-out="object.refund_amount" t-options='{"widget":"monetary","display_currency":object.currency_id}'/></li>
                    </ul>
                    <p>Số tiền sẽ được hoàn trong 7-10 ngày làm việc. Trân trọng.</p>
                </div>
            </field>
        </record>

        <!-- Nhắc khởi hành → khách hàng -->
        <record id="mail_template_departure_reminder" model="mail.template">
            <field name="name">Touriha: Nhắc khởi hành</field>
            <field name="model_id" ref="touriha_operations.model_touriha_tour"/>
            <field name="subject">Nhắc khởi hành tour {{ object.name }} ngày {{ object.start_date }}</field>
            <field name="email_to">{{ object.customer_id.email }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html">
                <div style="font-family:Arial,sans-serif;font-size:14px">
                    <p>Kính gửi <t t-out="object.customer_id.name or 'Quý khách'"/>,</p>
                    <p>Tour <b><t t-out="object.name or ''"/></b> của quý khách sắp khởi hành ngày
                       <b><t t-out="object.start_date or ''"/></b>.</p>
                    <p>Vui lòng chuẩn bị giấy tờ và có mặt đúng giờ. Chúc quý khách chuyến đi vui vẻ!</p>
                </div>
            </field>
        </record>

    </data>
</odoo>
